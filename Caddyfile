# NOTE: alive.best subdomain entries are added dynamically by deploy-site-systemd.sh
# When a new subdomain is deployed, the script adds an entry like:
# alice.alive.best {
#     import common_headers
#     reverse_proxy localhost:3349 { ... }
# }

