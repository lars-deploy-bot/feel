{
  "name": "@webalive/sandbox",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@webalive/database": "workspace:*",
    "@webalive/shared": "workspace:*",
    "e2b": "^2.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
