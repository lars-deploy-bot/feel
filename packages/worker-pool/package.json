{
  "name": "@webalive/worker-pool",
  "version": "1.0.0",
  "description": "Persistent worker pool for Claude Agent SDK with Unix socket IPC",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/worker-entry.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run",
    "check:imports": "node scripts/check-import-order.mjs",
    "lint": "biome lint . && bun run check:imports",
    "format": "biome format --write .",
    "ci": "biome ci . && bun run check:imports",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/node": "^10.45.0",
    "@webalive/runtime-auth": "workspace:*",
    "@webalive/sandbox": "workspace:*",
    "@webalive/shared": "workspace:*",
    "@webalive/tools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "worker-pool",
    "claude",
    "ipc",
    "unix-socket",
    "persistent-worker"
  ],
  "author": "WebAlive",
  "license": "MIT"
}
