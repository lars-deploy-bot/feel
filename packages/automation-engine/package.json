{
  "name": "@webalive/automation-engine",
  "version": "1.0.0",
  "description": "Automation engine: claim/execute/finish lifecycle, run-log, shared types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "@supabase/supabase-js": "^2.99.3",
    "@webalive/automation": "workspace:*",
    "@webalive/database": "workspace:*",
    "@webalive/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
