{
  "name": "@webalive/site-controller",
  "version": "1.0.0",
  "description": "Shell-Operator Pattern implementation for website deployment",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "test": "VITEST=true SERVER_CONFIG_PATH=${SERVER_CONFIG_PATH:-/var/lib/alive/server-config.json} bun test --timeout 20000",
    "clean": "rm -rf dist",
    "setup:validate": "bun run src/infra/validate-setup.ts",
    "routing:generate": "bun run src/infra/generate-routing.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@webalive/shared": "workspace:*",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "deployment",
    "systemd",
    "website",
    "orchestration"
  ],
  "author": "WebAlive",
  "license": "MIT"
}
