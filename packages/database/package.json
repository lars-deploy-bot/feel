{
  "name": "@webalive/database",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle-client.d.ts",
      "import": "./dist/drizzle-client.js"
    }
  },
  "scripts": {
    "build": "tsc && bun run verify:node-entrypoints",
    "dev": "tsc --watch",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci . && bun run verify:node-entrypoints",
    "verify:node-entrypoints": "node ./scripts/verify-node-entrypoints.mjs",
    "gen:types": "bun run scripts/generate-types.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit introspect",
    "db:setup": "bun run scripts/setup-database.ts",
    "db:seed": "bash scripts/seed.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
