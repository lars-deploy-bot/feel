{
  "name": "@webalive/tools",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./display": {
      "import": "./dist/display.js",
      "types": "./dist/display.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/assets dist/",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@alive-brug/alrighty": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@webalive/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.0"
  }
}
