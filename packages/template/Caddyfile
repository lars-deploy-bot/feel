# Caddyfile for DOMAIN
# Port: PORT

DOMAIN {
    import common_headers
    import image_serving
    reverse_proxy localhost:PORT {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
