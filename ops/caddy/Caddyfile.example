# Legacy example Caddyfile for Alive
# Prefer generated routing via /var/lib/alive/generated/Caddyfile.sites
# See: ops/caddy/etc/Caddyfile.example
#
# Requires: import /path/to/ops/caddy/Caddyfile.snippets
# (provides common_headers, block_internal_api, image_serving, preview_auth)

# Main app
bridge.example.com {
    import common_headers
    import block_internal_api

    reverse_proxy localhost:9000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Preview subdomains (optional)
*.preview.example.com {
    import common_headers
    import block_internal_api
    reverse_proxy localhost:9000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
