# WebAlive sites managed by Alive
#
# NOTE: Site routing is generated from the database and written to:
#   /var/lib/alive/generated/Caddyfile.sites
#
# This file only defines shared snippets and imports the generated routing.
# Any legacy/manual domains that are NOT in the database are preserved below.

(disable_acme) {
    tls {
        issuer internal
    }
}

# Shared snippets (common_headers, image_serving, preview_auth)
import /root/webalive/alive/ops/caddy/Caddyfile.snippets

# Generated site routing (database-driven, filtered for reserved domains)
# Each environment generates its own file from its own DB.
# Glob picks up all: Caddyfile.sites.filtered, Caddyfile.staging-sites.filtered, etc.
import /var/lib/alive/generated/Caddyfile.*sites.filtered

# Stealth scraping proxy
scrape.alive.best {
    tls force_automate
    reverse_proxy localhost:1234
}

# scalotta.it: serve the site, scalotta.alive.best: redirect to it
# Custom domain — scalotta.alive.best is in generated/Caddyfile.sites
scalotta.it {
    tls force_automate
    import common_headers
    import image_serving
    reverse_proxy localhost:3687 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}

# Legacy/manual domains not present in database (auto-preserved)
shell.terminal.goalive.nl {
    reverse_proxy localhost:3888
}

sk.goalive.nl {
    reverse_proxy localhost:3888
}

dreammachinetest.alive.best {
    import common_headers
    import image_serving
    reverse_proxy localhost:3354 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

sk-goalive-nl.preview.terminal.goalive.nl {
    import disable_acme
    import image_serving

    reverse_proxy localhost:3888 {
        header_up Host localhost
    }

    header {
        # Security headers (embeddable variant)
        -X-Frame-Options
        Content-Security-Policy "frame-ancestors https://dev.terminal.goalive.nl https://staging.terminal.goalive.nl https://terminal.goalive.nl"
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        -Server
        -X-Powered-By
    }

    # Auth check via forward_auth (direct to localhost to avoid redirect loops)
    forward_auth localhost:9000 {
        uri /api/auth/preview-guard?{query}
        copy_headers Cookie X-Preview-Set-Cookie
    }

    # Map X-Preview-Set-Cookie from forward_auth to Set-Cookie response header
    @has_preview_cookie header X-Preview-Set-Cookie *
    header @has_preview_cookie +Set-Cookie "{http.request.header.X-Preview-Set-Cookie}"
}

