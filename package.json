{
  "name": "claude-bridge-mono",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "cleanup-test-db": "bun scripts/cleanup-test-database.ts",
    "deploy": "./scripts/build-and-serve.sh",
    "deploy-site": "./scripts/deploy-site-systemd.sh",
    "dev": "turbo run dev",
    "e2e": "cd apps/web && bun run test:e2e",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "knip": "knip --no-progress",
    "depcruise": "depcruise apps/web --config .dependency-cruiser.json",
    "pretest": "knip --no-progress && bun run depcruise",
    "test": "cd packages/tools && bun test && cd ../.. && cd apps/web && bun run test",
    "postinstall": "cd packages/template/user && bun install && cd ../../.. && ./scripts/link-workspace-deps.sh",
    "pull": "GIT_SSH_COMMAND='ssh -i ~/.ssh/alive_brug_deploy' git pull",
    "push": "GIT_SSH_COMMAND='ssh -i ~/.ssh/alive_brug_deploy' git push",
    "see": "pm2 logs claude-bridge --lines 1000",
    "see:staging": "pm2 logs claude-bridge-staging --lines 1000",
    "setup": "./scripts/setup/copy-template.sh",
    "setup-webhook": "./scripts/setup-webhook.sh",
    "staging": "bun run lint && cd packages/images && bun run build && cd ../tools && bun run build && cd ../.. && pm2 restart claude-bridge-staging --update-env && sleep 5 && echo '\\n✅ Testing staging login...' && curl -f -X POST http://localhost:8998/api/login -H 'Content-Type: application/json' -d '{\"email\":\"eedenlars@gmail.com\",\"password\":\"supersecret\"}' && echo '\\n✅ Staging login verified!' && pm2 describe claude-bridge-staging",
    "start": "turbo run start",
    "superclean": "./scripts/superclean.ts",
    "update-cors": "./scripts/update-cors-domains.sh",
    "web": "cd apps/web && bun run dev",
    "widget": "cd apps/widget-server && ./build.sh && go run main.go"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@playwright/test": "^1.56.1",
    "@types/jsonwebtoken": "^9.0.10",
    "dependency-cruiser": "^17.3.1",
    "dotenv": "^17.2.3",
    "knip": "^5.69.1",
    "turbo": "^2.6.1"
  },
  "dependencies": {
    "@types/node": "^24.10.0",
    "groq-sdk": "^0.34.0",
    "jsonwebtoken": "^9.0.2",
    "msgpackr": "^1.11.5",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "react-markdown": "^10.1.0",
    "ws": "^8.18.3"
  }
}
