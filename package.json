{
  "name": "claude-bridge-mono",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "HOSTED_ENV=computer ./scripts/deployment/deploy-dev.sh",
    "dev:turbo": "turbo run dev",
    "start": "turbo run start",
    "web": "cd apps/web && bun run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "static-check": "turbo run type-check lint format && bun run unit",
    "knip": "knip --no-progress",
    "depcruise": "depcruise apps/web --config .dependency-cruiser.json",
    "test": "cd packages/tools && bun test && cd ../.. && cd apps/web && bun run test",
    "unit": "cd packages/tools && bun test && cd ../.. && cd apps/web && bun run test",
    "e2e": "cd apps/web && bun run test:e2e",
    "gates": "cd apps/web && bun run test:gates",
    "postinstall": "bun run prepare:repo",
    "prepare": "husky",
    "prepare:repo": "bun run setup:template && bun run build:libs",
    "setup:template": "cd templates/site-template/user && bun install",
    "build:libs": "turbo run build --filter='!apps/*'",
    "setup": "./scripts/setup/copy-template.sh",
    "pull": "GIT_SSH_COMMAND='ssh -i ~/.ssh/alive_brug_deploy' git pull",
    "push": "GIT_SSH_COMMAND='ssh -i ~/.ssh/alive_brug_deploy' git push",
    "cleanup-test-db": "bun scripts/database/cleanup-test-database.ts",
    "superclean": "bun scripts/database/superclean.ts",
    "gen:db": "./scripts/database/generate-types.sh",
    "deploy-site": "bun scripts/test-deployment.ts",
    "setup-webhook": "./scripts/maintenance/setup-webhook.sh",
    "update-cors": "./scripts/maintenance/update-cors-domains.sh",
    "widget": "cd apps/widget-server && ./build.sh && go run main.go",
    "redis:install": "bun --filter @alive-brug/redis install",
    "redis:start": "bun --filter @alive-brug/redis start",
    "redis:stop": "bun --filter @alive-brug/redis stop",
    "redis:status": "bun --filter @alive-brug/redis status",
    "redis:logs": "bun --filter @alive-brug/redis logs",
    "redis:cli": "bun --filter @alive-brug/redis cli",
    "redis:health": "bun --filter @alive-brug/redis health",
    "redis:test": "bun --filter @alive-brug/redis test",
    "see": "pm2 logs claude-bridge --lines 1000",
    "see:dev": "pm2 logs claude-bridge-dev --lines 1000"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,md}": [
      "biome format --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@playwright/test": "^1.56.1",
    "@types/jsonwebtoken": "^9.0.10",
    "dependency-cruiser": "^17.3.1",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "knip": "^5.69.1",
    "lint-staged": "^16.2.7",
    "turbo": "^2.6.1"
  },
  "dependencies": {
    "@types/node": "^24.10.0",
    "groq-sdk": "^0.34.0",
    "jsonwebtoken": "^9.0.2",
    "msgpackr": "^1.11.5",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "node-pty": "^1.0.0",
    "react-markdown": "^10.1.0",
    "ws": "^8.18.3"
  }
}
