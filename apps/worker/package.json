{
  "name": "@webalive/worker",
  "version": "1.0.0",
  "description": "Automation scheduler. Finds due jobs, delegates execution to the web app.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@sentry/node": "^10.45.0",
    "@supabase/supabase-js": "^2.99.3",
    "@webalive/database": "workspace:*",
    "@webalive/env": "workspace:*",
    "@webalive/shared": "workspace:*",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
