{
  "name": "shell-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build && node dist/index.js",
    "dev:watch": "nodemon --watch src --exec 'bun run build && node dist/index.js'",
    "build": "bun run build:server && bun run build:client && bun run build:css && rm -rf dist/templates && cp -r src/templates dist/templates",
    "build:server": "tsc --noEmit && NODE_ENV=production bun build src/index.ts --outdir dist --target node --define process.env.NODE_ENV='\"production\"' --external=@webalive/* --external=@alive-brug/*",
    "build:client": "vite build",
    "build:css": "npx tailwindcss -i src/client/styles/shell.css -o dist/client/shell.css --minify",
    "start": "node dist/index.js",
    "test": "bun test __tests__/build-verification.test.ts",
    "type-check": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.5",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.2.0",
    "@webalive/shared": "workspace:*",
    "@webalive/site-controller": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "adm-zip": "^0.5.16",
    "cookie": "^1.0.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.6.16",
    "node-pty": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "tailwindcss": "^4.1.17",
    "ws": "^8.18.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "@types/adm-zip": "^0.5.7",
    "@types/bun": "^1.3.2",
    "@types/cookie": "^0.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "nodemon": "^3.1.11",
    "typescript": "^5.0.0",
    "vite": "^6.0.3"
  }
}
