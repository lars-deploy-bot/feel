{
  "name": "@webalive/browser-control",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun src/server.ts",
    "dev": "bun --watch src/server.ts",
    "build": "tsc",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "playwright-core": "^1.52.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/node": "24.9.1",
    "typescript": "5.9.3",
    "vitest": "4.0.17"
  }
}
