{
  "name": "@webalive/mcp-google-search-console",
  "version": "1.0.0",
  "description": "Google Search Console MCP server with Bearer token authentication. Provides Claude with search analytics, URL inspection, and site listing tools.",
  "author": "WebAlive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lars-deploy-bot/feel",
    "directory": "apps/mcp-servers/google-search-console"
  },
  "keywords": [
    "mcp",
    "google-search-console",
    "seo",
    "oauth",
    "model-context-protocol"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-google-search-console": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^13.1.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.0"
  }
}
