{
  "name": "@webalive/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo -p 8997",
    "dev:test": "next dev -p 9547",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start -p 9000",
    "dev:deploy": "cd ../.. && bun run dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci . && bun run check:stream-type-assertions && bun run check:tools-import-safety",
    "check:stream-type-assertions": "bun run scripts/check-no-stream-type-assertions.ts",
    "check:tools-import-safety": "bun run scripts/check-tools-import-safety.ts",
    "tsc": "tsgo --noEmit",
    "type-check": "tsgo --noEmit",
    "pretest": "bun run scripts/check-test-imports.ts",
    "test": "bun run test:unit",
    "test:unit": "vitest run",
    "test:db": "vitest run -c vitest.db.config.ts",
    "test:sys": "vitest run -c vitest.system.config.ts",
    "test:ci": "bun run test:unit && bun run test:db && bun run test:sys",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:e2e": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test",
    "test:e2e:isolated": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/test-e2e-debug.sh",
    "test:e2e:ui": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test --ui",
    "test:e2e:headed": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test --headed",
    "test:e2e:debug": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test --debug",
    "test:e2e:gate": "E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.gate.config.ts",
    "test:e2e:live": "ENV_FILE=${ENV_FILE:-.env.staging} E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts",
    "test:e2e:deploy-live": "ENV_FILE=${ENV_FILE:-.env.staging} E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts e2e-tests/deploy-live.spec.ts",
    "test:e2e:live:ui": "ENV_FILE=.env.staging E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts --ui",
    "test:e2e:live:headed": "ENV_FILE=.env.staging E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts --headed",
    "test:e2e:staging": "ENV_FILE=.env.staging E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts",
    "test:e2e:staging:ui": "ENV_FILE=.env.staging E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts --ui",
    "test:e2e:critical": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test chat-critical.spec.ts",
    "test:e2e:critical:10x": "for i in $(seq 1 10); do echo \"--- Run $i/10 ---\" && ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test chat-critical.spec.ts || exit 1; done && echo '10/10 passed'",
    "test:e2e:critical:live": "ENV_FILE=${ENV_FILE:-.env.staging} E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts chat-critical-live.spec.ts",
    "test:gates": "ENV_FILE=.env.e2e.local E2E_STRICT_API_GUARD=1 bash scripts/run-local-e2e.sh bash ../../scripts/playwright/run.sh test auth.spec.ts protection-verification.spec.ts org-workspace-selection.spec.ts chat-improved.spec.ts chat-critical.spec.ts deploy.spec.ts && ENV_FILE=.env.staging E2E_STRICT_API_GUARD=1 bash ../../scripts/playwright/run.sh test --config=playwright.live.config.ts chat-live.spec.ts chat-critical-live.spec.ts",
    "check:unregistered-domains": "bun run scripts/check-unregistered-domains.ts",
    "register:unregistered-domains": "bun run scripts/register-unregistered-domains.ts"
  },
  "dependencies": {
    "@alive-brug/alrighty": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/gmail": "^16.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@webalive/automation": "workspace:*",
    "@webalive/automation-engine": "workspace:*",
    "@webalive/database": "workspace:*",
    "@webalive/env": "workspace:*",
    "@webalive/images": "workspace:*",
    "@webalive/oauth-core": "workspace:*",
    "@webalive/org": "workspace:*",
    "@webalive/redis": "workspace:*",
    "@webalive/runtime-auth": "workspace:*",
    "@webalive/sandbox": "workspace:*",
    "@webalive/shared": "workspace:*",
    "@webalive/site-controller": "workspace:*",
    "@webalive/tools": "workspace:*",
    "@webalive/worker-pool": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "croner": "^10.0.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.3",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.362.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260310.1",
    "autoprefixer": "^10.4.27",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.0"
  }
}
