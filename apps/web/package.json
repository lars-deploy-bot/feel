{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo -p $(node -p \"require('../../bridge.config.js').ports.dev\")",
    "dev:test": "next dev -p 9547",
    "build": "next build",
    "start": "next start -p $(node -p \"require('../../bridge.config.js').ports.production\")",
    "dev:deploy": "cd ../.. && bun run dev",
    "lint": "biome lint .",
    "format": "npx biome format --write .",
    "tsc": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "pretest": "bun run scripts/check-test-imports.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:isolated": "bash scripts/test-e2e-debug.sh",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:genuine": "playwright test --config=playwright.genuine.config.ts",
    "test:e2e:genuine:ui": "playwright test --config=playwright.genuine.config.ts --ui",
    "test:e2e:genuine:headed": "playwright test --config=playwright.genuine.config.ts --headed",
    "test:e2e:staging": "TEST_ENV=staging playwright test org-workspace-selection.spec.ts",
    "test:e2e:staging:ui": "TEST_ENV=staging playwright test org-workspace-selection.spec.ts --ui",
    "test:gates": "playwright test smoke.spec.ts auth.spec.ts protection-verification.spec.ts org-workspace-selection.spec.ts chat.spec.ts deploy.spec.ts && playwright test --config=playwright.genuine.config.ts chat-genuine.spec.ts",
    "gen:db": "bun run scripts/generate-db-types-improved.ts",
    "gen:db:force": "rm -rf .tmp/supabase && bun run scripts/generate-db-types-improved.ts"
  },
  "dependencies": {
    "@alive-brug/images": "workspace:*",
    "@alive-brug/tools": "workspace:*",
    "@webalive/site-controller": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.1.25",
    "@anthropic-ai/sdk": "^0.67.0",
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.81.1",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "framer-motion": "^11.11.1",
    "groq-sdk": "^0.34.0",
    "jose": "^6.1.2",
    "lucide-react": "^0.546.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.52.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.15",
    "zod": "~3.25.0",
    "zustand": "^4.5.2",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@tailwindcss/postcss": "^4.1.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "24.9.1",
    "@types/react": "19.2.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.7",
    "happy-dom": "^20.0.10",
    "postcss": "^8.4.47",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6"
  }
}
