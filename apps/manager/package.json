{
  "name": "@webalive/manager",
  "version": "0.0.1",
  "private": true,
  "description": "Manager dashboard — React + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5090",
    "build": "vite build",
    "start": "bun server.ts",
    "preview": "vite preview --port 5090",
    "test": "vitest run",
    "test:e2e": "bash ../../scripts/playwright/run.sh test",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@webalive/database": "workspace:*",
    "@webalive/shared": "workspace:*",
    "nuqs": "^2.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
