{
  "name": "@webalive/api",
  "version": "0.0.1",
  "description": "Alive API — Hono on Bun",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:e2e": "vitest run src/__tests__/e2e",
    "type-check": "tsgo --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "@supabase/supabase-js": "^2.99.3",
    "@webalive/automation": "workspace:*",
    "@webalive/database": "workspace:*",
    "@webalive/env": "workspace:*",
    "@webalive/shared": "workspace:*",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@types/bun": "^1.3.11",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
