{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?read_only=true&features=docs%2Cdatabase%2Cdebugging%2Cdevelopment"
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@0.0.68",
        "--headless",
        "--no-sandbox",
        "--caps",
        "devtools",
        "--ignore-https-errors",
        "--output-dir",
        "./.playwright-mcp"
      ],
      "env": {
        "TMPDIR": "./.tmp",
        "BUN_INSTALL_CACHE_DIR": "./.tmp/bun-cache"
      }
    }
  }
}
