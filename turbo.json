{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.json", "tsconfig.base.json", "biome.json"],
  "globalEnv": ["CI", "NODE_ENV", "VERCEL", "VERCEL_ENV", "VERCEL_URL"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": ["ANTHROPIC_API_KEY", "ANTH_API_SECRET", "ALIVE_ENV", "LOCAL_TEMPLATE_PATH", "PLAYWRIGHT_TEST"]
    },
    "ci": {
      "inputs": ["$TURBO_DEFAULT$", "biome.json"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.spec.ts", "!**/__tests__/**"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/lock", "dist/**"],
      "env": [
        "ANTHROPIC_API_KEY",
        "ANTH_API_SECRET",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_PREVIEW_BASE",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "NEXT_PUBLIC_CONTACT_EMAIL",
        "NEXT_PUBLIC_SENTRY_DSN",
        "CLAUDE_MODEL",
        "ALIVE_PASSCODE",
        "SIGNUP_ACCESS_CODE",
        "ALIVE_ENV",
        "GROQ_API_SECRET",
        "REDIS_URL",
        "GITHUB_WEBHOOK_SECRET",
        "DEPLOY_BRANCH",
        "LOCAL_TEMPLATE_PATH",
        "JWT_SECRET",
        "JWT_ES256_PRIVATE_KEY",
        "INTERNAL_TOOLS_SECRET",
        "IMAGES_SIGNATURE_SECRET",
        "POLAR_ACCESS_TOKEN",
        "POLAR_WEBHOOK_SECRET",
        "SERVER_CONFIG_PATH",
        "E2B_API_KEY",
        "ALIVE_ENV",
        "ALIVE_BUILD_COMMIT",
        "ALIVE_BUILD_BRANCH",
        "ALIVE_BUILD_TIME",
        "NEXT_PUBLIC_SENTRY_RELEASE",
        "NEXT_PUBLIC_ALIVE_ENV",
        "NEXT_PUBLIC_BUILD_COMMIT",
        "NEXT_PUBLIC_BUILD_BRANCH",
        "NEXT_PUBLIC_BUILD_TIME",
        "NEXT_PUBLIC_SERVER_IP"
      ]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.spec.ts"],
      "outputs": []
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "biome.json"],
      "outputs": []
    },
    "format": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.json", "biome.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["coverage/**"],
      "env": ["VITEST_POOL_ID"]
    },
    "@webalive/redis#start": {
      "cache": false,
      "persistent": true
    },
    "@webalive/redis#stop": {
      "cache": false
    },
    "@webalive/redis#status": {
      "cache": false
    },
    "@webalive/redis#health": {
      "cache": false
    },
    "@webalive/image-processor#build": {
      "outputs": []
    },
    "@webalive/worker#start": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": ["SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY", "JWT_SECRET", "WORKER_PORT"]
    },
    "@webalive/worker#dev": {
      "cache": false,
      "persistent": true,
      "env": ["SUPABASE_URL", "SUPABASE_SERVICE_ROLE_KEY", "JWT_SECRET", "WORKER_PORT"]
    },
    "@webalive/site-controller#test": {
      "env": ["SERVER_CONFIG_PATH"]
    }
  }
}
